{
  "name": "praman-network",
  "private": true,
  "version": "1.0.0",
  "packageManager": "npm@11.16.0",
  "description": "Praman Network Ecosystem Monorepo",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "clean": "rm -rf node_modules apps/*/node_modules packages/*/node_modules apps/*/dist"
  },
  "devDependencies": {
    "turbo": "^2.0.4"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.2",
    "ethers": "^6.17.0",
    "uuid": "^14.0.1"
  }
}
